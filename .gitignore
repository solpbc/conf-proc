# macOS / editors
.DS_Store
.AppleDouble
.LSOverride
._*
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Local configuration and credentials
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.der
*.bin
*.quote
*.report
hcl-blob*
nonce*

# Pinned public AMD trust roots used by verifier.py.
!roots/
!roots/amd/
!roots/amd/*/
!roots/amd/*/*.pem

# Logs and temporary output
*.log
*.tmp
tmp/
